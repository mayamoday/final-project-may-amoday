## Step 16 — Add Create Operation for Study Sessions

```js
const createSession = async (title, description) => {
  const { data: { user } } = await supabase.auth.getUser()
  const { data, error } = await supabase
    .from('study_sessions')
    .insert([{ title, description, user_id: user.id }])
    .select()
  if (!error) setSessions(prev => [data[0], ...prev])
}
```

---

## Step 17 — Add Update and Delete for Study Sessions

```js
// Update a session
const updateSession = async (id, updates) => {
  const { error } = await supabase
    .from('study_sessions')
    .update(updates)
    .eq('id', id)
  if (!error) setSessions(prev =>
    prev.map(s => s.id === id ? { ...s, ...updates } : s)
  )
}

// Delete a session
const deleteSession = async (id) => {
  const { error } = await supabase
    .from('study_sessions')
    .delete()
    .eq('id', id)
  if (!error) setSessions(prev => prev.filter(s => s.id !== id))
}
```

---

## Step 18 — Repeat Pattern for Tasks

```js
// Read tasks for a session
const fetchTasks = async (sessionId) => {
  const { data, error } = await supabase
    .from('tasks')
    .select('*')
    .eq('session_id', sessionId)
  if (!error) setTasks(data)
}

// Create a task
const createTask = async (title, sessionId) => {
  const { data: { user } } = await supabase.auth.getUser()
  const { data, error } = await supabase
    .from('tasks')
    .insert([{ title, session_id: sessionId, user_id: user.id }])
    .select()
  if (!error) setTasks(prev => [...prev, data[0]])
}

// Update a task (e.g. toggle completed)
const updateTask = async (id, updates) => {
  const { error } = await supabase
    .from('tasks')
    .update(updates)
    .eq('id', id)
  if (!error) setTasks(prev =>
    prev.map(t => t.id === id ? { ...t, ...updates } : t)
  )
}

// Delete a task
const deleteTask = async (id) => {
  const { error } = await supabase
    .from('tasks')
    .delete()
    .eq('id', id)
  if (!error) setTasks(prev => prev.filter(t => t.id !== id))
}
```

---

## Step 19 — Repeat Pattern for Profiles

```js
// Read own profile
const fetchProfile = async () => {
  const { data: { user } } = await supabase.auth.getUser()
  const { data, error } = await supabase
    .from('profiles')
    .select('*')
    .eq('user_id', user.id)
    .single()
  if (!error) setProfile(data)
}

// Update own profile
const updateProfile = async (updates) => {
  const { data: { user } } = await supabase.auth.getUser()
  const { error } = await supabase
    .from('profiles')
    .update(updates)
    .eq('user_id', user.id)
  if (!error) setProfile(prev => ({ ...prev, ...updates }))
}
```

